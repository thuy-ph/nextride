# The default is live: the server reads ThemeParks.wiki from the server side.
# Set to demo only if you need an offline predictable interface.
PARK_DATA_MODE=live

# Optional: replace when you have a licensed/official data provider.
THEMEPARKS_API_BASE=https://api.themeparks.wiki/v1

# The public provider asks clients to poll no more than every five minutes.
LIVE_CACHE_SECONDS=300
